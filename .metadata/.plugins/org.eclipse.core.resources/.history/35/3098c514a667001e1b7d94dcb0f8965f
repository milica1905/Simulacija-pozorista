	    @FXML
		void rezervacija_karte(ActionEvent event) {
				   
			       // Prvo, proverimo da li je izabrana predstava iz liste predstava
			       Predstava selectedPredstava = ListView_Lista_predstava.getSelectionModel().getSelectedItem();
			       if (selectedPredstava == null) {
			           // Ako nije izabrana predstava, prikažemo poruku korisniku da izabere predstavu
			           Alert alert = new Alert(Alert.AlertType.ERROR);
			           alert.setTitle("Greška");
			           alert.setHeaderText("Molimo izaberite predstavu za koju želite da rezervišete kartu.");
			           alert.showAndWait();
			           return;
			       }

			       // Zatim, proverimo da li je broj rezervisanih karata unet
			       String brojKarataString = textField_broj_rezervisanih_karata.getText();
			       if (brojKarataString.isEmpty()) {
			           // Ako broj karata nije unet, prikažemo poruku korisniku da unese broj karata
			           Alert alert = new Alert(Alert.AlertType.ERROR);
			           alert.setTitle("Greška");
			           alert.setHeaderText("Molimo unesite broj rezervisanih karata.");
			           alert.showAndWait();
			           return;
			       }

			       try {
			           // Pretvaramo uneseni broj karata u integer
			           int brojKarata = Integer.parseInt(brojKarataString);

			           // Proverimo dostupnost karata
			   			Object selectedObject = ListView_Lista_pozorista.getSelectionModel().getSelectedItem();
			   			if (selectedObject instanceof Pozoriste) 
			   				izabranoPozoriste = (Pozoriste) selectedObject;
			           int izvodjenjePredstaveID = Izvodjenje_predstave.izvodjenje_pozID(selectedPredstava.getId()).getId();
			           int brojSjedista = Pozoriste.dajBrojSlobodnihSjedista(izabranoPozoriste,Izvodjenje_predstave.vratiIzvodjenjeNaOsnovuID(izvodjenjePredstaveID)); 
			           
			           int slobodanBroj = Karta.sljedeciSlobodanBroj(izvodjenjePredstaveID, brojSjedista);

			           if (slobodanBroj > brojSjedista) {
			               // Nema dovoljno slobodnih mesta za rezervaciju
			               Alert alert = new Alert(Alert.AlertType.ERROR);
			               alert.setTitle("Greška");
			               alert.setHeaderText("Nema dovoljno slobodnih mesta za rezervaciju " + brojKarata + " karte/a.");
			               alert.showAndWait();
			           } else {
			               // Provera datuma izvođenja predstave
			        	   Izvodjenje_predstave izvodjenje = Izvodjenje_predstave.izvodjenje_pozID(selectedPredstava.getId());
			               Timestamp datumPredstave = izvodjenje.getDatum_i_vrijeme();
			               if (!Izvodjenje_predstave.daLiSeIzvodiUNarednomPeriodu(datumPredstave)) {
			                   // Predstava se ne izvodi u narednom periodu
			                   Alert alert = new Alert(Alert.AlertType.ERROR);
			                   alert.setTitle("Greška");
			                   alert.setHeaderText("Izabrana predstava se ne izvodi u narednom periodu i ne možete je rezervisati.");
			                   alert.showAndWait();
			                   return;
			               }
			               
			               // Stvaramo nove karte i dodajemo ih u listu karata sa statusom "rezervisana koristeći aplikaciju, ali nije preuzeta"
			               for (int i = 0; i < brojKarata; i++) {
			                   Karta novaKarta = new Karta(-1,izvodjenjePredstaveID, 2, KontrolerMain.getIdPosjetioca(), slobodanBroj);
			                   Karta.getLista_karata().add(novaKarta);
			                   slobodanBroj++;
			               }

			               // Ažuriramo status karata u bazi podataka ili obavljamo odgovarajuće radnje za praćenje rezervacija

			               // Nakon uspešne rezervacije, možete prikazati potvrdu korisniku
			               Alert alert = new Alert(Alert.AlertType.INFORMATION);
			               alert.setTitle("Uspešna rezervacija");
			               alert.setHeaderText("Uspešno ste rezervisali " + brojKarata + " karte/a za predstavu: " + selectedPredstava.getNaziv());
			               alert.showAndWait();
			               
			               try {
								connect = Konekcija.getConnection();
								boolean dodavanjekarte = false;
								try {
									statement = connect.prepareStatement("INSERT INTO karta (izvodjenje_predstave_id, status, posjetilac_id, broj_karta) VALUE (?,?,?,?)");
									statement.setInt(1, izvodjenjePredstaveID);
									statement.setInt(2, 2);
									statement.setInt(3, KontrolerMain.getIdPosjetioca());
									statement.setInt(4, brojKarata);
									statement.executeUpdate();
									Konekcija.ucitajPodatke();
									dodavanjekarte = true;
								} catch (Exception e) {
									e.printStackTrace();
								}

								if (connect != null) {
									try {
										connect.close();
									} catch (SQLException e) {
										e.printStackTrace();
									}
								}
			               // Takođe, možete ažurirati informacije o broju slobodnih karata za izabranu predstavu
			               // kako bi se prikazale tačne informacije korisnicima.

			               // Ako želite promeniti status karata u bazi podataka, to možete uraditi ovde.
			           

			       } catch (NumberFormatException e) {
			           // U slučaju da korisnik nije unio ispravan broj karata, prikažemo poruku o grešci
			           Alert alert1 = new Alert(Alert.AlertType.ERROR);
			           alert.setTitle("Greška");
			           alert.setHeaderText("Neispravan format broja rezervisanih karata.");
			           alert.showAndWait();
			       }
			           }
			   }
			           catch (Exception e) {
			   			e.printStackTrace();
			   		}
			       
			       }

	    
