				new Radnik_Pozorista(Rs7.getInt("id"), Rs7.getString("ime"), Rs7.getString("prezime"),Rs7.getString("korisnicko_ime"), Rs7.getString("lozinka"),Rs7.getInt("pozoriste_id"));
				
			}

		} catch (Exception e) {
			e.printStackTrace();
		}
		if (myConn != null) {
			try {
				myConn.close();
			} catch (SQLException e) {
				e.printStackTrace();
			}
		}
	}
	
