	    @FXML
	    void prijava_radnik_klik(ActionEvent event) {
	    	if(korisnicko_radnik_id.getText().equals("") && lozinka_radnik_id.getText().equals("")) {
	    		Alert alert_prazna_polja = new Alert(Alert.AlertType.ERROR);
	    		alert_prazna_polja.setContentText("Polja ne mogu biti prazna! Molimo popunite polja.");
	    		alert_prazna_polja.show();
	    	}
	    	else if(korisnicko_radnik_id.getText().equals("")) {
	    		Alert alert_prazno_korisnicko = new Alert(Alert.AlertType.ERROR);
	    		alert_prazno_korisnicko.setContentText("Vaše polje je prazno. Molimo unesite korisnicko ime!");
	    		alert_prazno_korisnicko.show();
	    	}
			
	    	else if(lozinka_radnik_id.getText().equals("")) {
	    		Alert alert_prazna_lozinka = new Alert(Alert.AlertType.ERROR);
	    		alert_prazna_lozinka.setContentText("Vaše polje je prazno. Molimo unesite lozinku!");
	    		alert_prazna_lozinka.show();
	    	}
	    	else {
	    		boolean postojiRadnik = false;
	    		boolean tacnaSifra = true;
	    		String korisnickoIme = korisnicko_radnik_id.getText();

	    		for (Radnik_Pozorista radnici : Radnik_Pozorista.getLista_radnikaPozorista()) {
	    		    if (radnici.getKorisnicko_ime().equals(korisnickoIme)) {
	    		    	postojiRadnik = true;
	    		    	ime=radnici.getIme();
	    		    	prezime=radnici.getPrezime();
    
	    		        if (!radnici.getLozinka().equals(Radnik_Pozorista.getMd5(lozinka_radnik_id.getText())))
	    		        	tacnaSifra=false;
	    		    } 
	    		}    
	    		
	    		if(!postojiRadnik) {
		   			Alert alert_ne_postoji_korisnicko = new Alert(Alert.AlertType.WARNING);
		   			alert_ne_postoji_korisnicko.setTitle("UPOZORENJE");
		   			alert_ne_postoji_korisnicko.setContentText("Korisnicko ime: " + korisnicko_radnik_id.getText() + " ne postoji.Pokušajte ponovo");
		   			alert_ne_postoji_korisnicko.show();
		   			korisnicko_radnik_id.setText("");
		   			lozinka_radnik_id.setText("");
	   			}
	    		        
	    		if (postojiRadnik && !tacnaSifra) {
	    		    lozinka_radnik_id.setText("");
	    		    Alert alert_neispravna_lozinka = new Alert(Alert.AlertType.WARNING);
	    		    alert_neispravna_lozinka.setTitle("UPOZORENJE");
	    		    alert_neispravna_lozinka.setContentText("Neispravna lozinka za " + korisnickoIme + ". Pokušajte ponovo");
	    		    alert_neispravna_lozinka.show();
	    		}
	    		else {
	    			try {
	    				pomocnoKorisnicko = korisnicko_radnik_id.getText();
	    	    		Parent root = FXMLLoader.load(getClass().getResource("Nakon_prijave_Radnika.fxml"));
	    	    		Stage stage = (Stage)((Node)event.getSource()).getScene().getWindow();
	    	    		Scene scene = new Scene(root);
	    	    		stage.setTitle("Dobrodošli radniče " + ime+ ", " + prezime);
	    	    		stage.setScene(scene);
	    	    		stage.show();
	        		 }
	        		 catch(Exception e) {
	        			 e.printStackTrace();
	        		 }
	        				
	    		 }
	    	}    
	    		    
	    		
	    		
	    		
	    }

	    @FXML
	    void switchtoVratiNaPocetnu(ActionEvent event) {
	    	Alert upozorenje = new Alert(Alert.AlertType.CONFIRMATION);
		 	upozorenje.setTitle("POVRATAK NAZAD");
		 	upozorenje.setContentText("Molimo Vas da potvrdite da želite da se vratite na pocetnu stranicu.");
	    
		 	Optional <ButtonType>result = upozorenje.showAndWait();
		 	if(result.get()==ButtonType.OK) {
			try {
				Parent root = FXMLLoader.load(getClass().getResource("Pocetna_scena.fxml"));
				Stage stage = (Stage)((Node)event.getSource()).getScene().getWindow();
				Scene scene = new Scene(root);
				stage.setTitle("DOBRODOSLI!");
				stage.setScene(scene);
				stage.show();
			}
			catch(IOException e) {
				e.printStackTrace();
			}
		 	}
	    }

