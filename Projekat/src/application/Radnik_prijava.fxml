      <Button fx:id="prijava_radnik_dugme" blendMode="OVERLAY" layoutX="246.0" layoutY="316.0" mnemonicParsing="false" onAction="#prijava_radnik_klik" text="Prijava">
         <font>
            <Font name="Georgia Italic" size="24.0" />
         </font>
      </Button>
      <Button fx:id="nazad_dugme" layoutX="533.0" layoutY="370.0" mnemonicParsing="false" onAction="#switchtoVratiNaPocetnu" style="-fx-background-color: transparent; -fx-underline: true;" text="Nazad">
         <font>
            <Font name="Georgia Italic" size="14.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
