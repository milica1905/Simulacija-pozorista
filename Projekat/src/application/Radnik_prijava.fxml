<AnchorPane prefHeight="410.0" prefWidth="602.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.Kontroler_Radnik_prijava">
   <children>
      <ImageView fitHeight="422.0" fitWidth="609.0" layoutX="-2.0" layoutY="-13.0" pickOnBounds="true">
         <image>
            <Image url="@../../../teatar%20pocetna.jpg" />
         </image>
         <effect>
            <MotionBlur angle="300.7" radius="28.91" />
         </effect>
      </ImageView>
      <Label layoutX="57.0" layoutY="143.0" text="Korisničko ime:">
         <font>
            <Font name="Georgia Italic" size="24.0" />
         </font>
      </Label>
      <Label layoutX="82.0" layoutY="191.0" text="Lozinka:">
         <font>
            <Font name="Georgia Italic" size="24.0" />
         </font>
      </Label>
      <TextField fx:id="korisnicko_radnik_id" layoutX="275.0" layoutY="143.0" promptText="Unesite korisničko ime...">
         <font>
            <Font name="Georgia Italic" size="16.0" />
         </font>
      </TextField>
      <PasswordField fx:id="lozinka_radnik_id" layoutX="246.0" layoutY="191.0" promptText="Unesite lozinku...">
         <font>
            <Font name="Georgia Italic" size="16.0" />
