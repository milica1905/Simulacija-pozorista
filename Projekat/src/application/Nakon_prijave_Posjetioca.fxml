            <Font name="Georgia Italic" size="14.0" />
         </font>
      </Button>
      <Button fx:id="spisak_osoblja_dugme" layoutX="217.0" layoutY="384.0" mnemonicParsing="false" onAction="#prikazi_spisak_osoblja" text="Spisak osoblja">
