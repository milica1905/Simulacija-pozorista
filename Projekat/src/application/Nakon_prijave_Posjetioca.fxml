<AnchorPane minHeight="-Infinity" prefHeight="630.0" prefWidth="525.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.Kontroler_Nakon_prijave_Posjetioca">
   <children>
      <ImageView fitHeight="630.0" fitWidth="540.0" pickOnBounds="true">
         <image>
            <Image url="@../../../slika9.jpg" />
