<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="410.0" prefWidth="602.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/19" fx:controller="application.Kontroler_Pocetna_scena">
   <children>
      <ImageView fitHeight="410.0" fitWidth="611.0" layoutX="-9.0">
         <image>
            <Image url="@../../../zavjesa.jpg" />
         </image>
      </ImageView>
      <Button fx:id="posjetilac_button" layoutX="121.0" layoutY="337.0" mnemonicParsing="false" onAction="#switchtoPosjetilacScene" prefHeight="32.0" prefWidth="117.0" text="Posjetilac">
         <font>
            <Font name="Lucida Calligraphy Italic" size="14.0" />
         </font>
      </Button>
      <Button fx:id="radnik_button" layoutX="346.0" layoutY="337.0" mnemonicParsing="false" onAction="#switchtoRadnikScene" prefHeight="32.0" prefWidth="117.0" text="Radnik">
         <font>
            <Font name="Lucida Calligraphy Italic" size="14.0" />
         </font>
      </Button>
      <Label fx:id="dobrodosli_labela" alignment="CENTER" contentDisplay="CENTER" layoutX="179.0" layoutY="164.0" prefHeight="49.0" prefWidth="236.0" text="Dobrodošli!" textFill="WHITE">
         <font>
            <Font name="Lucida Calligraphy Italic" size="30.0" />
         </font>
      </Label>
      <Label fx:id="identifikacija_labela" layoutX="159.0" layoutY="213.0" prefHeight="37.0" prefWidth="284.0" text="Molimo Vas da se identifikujete." textFill="WHITE">
         <font>
            <Font name="Lucida Calligraphy Italic" size="16.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
